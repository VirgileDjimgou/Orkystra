# Orkystra — Environment Variable Configuration
#
# Copy this file to .env and customize for your deployment.
# Environment variables override appsettings.json values.
# Use double-underscore (__) as the key separator for nested settings.
#
# Example: Security__ApiKey=my-secret-key overrides Security:ApiKey

# === Authentication ===
# REQUIRED. The API key all protected endpoints check against.
# Must be a non-empty value. Set this first or the API will not start.
Security__ApiKey=

# === Tenant ===
# Optional. Default tenant ID when tenant header is not required.
TenantAccess__DefaultTenantId=local-demo-tenant
# Set to "true" to require X-Tenant-Id on every request.
TenantAccess__RequireTenantHeader=false

# === Observability ===
# Optional. Path for the local JSONL audit log file.
Observability__AuditLogFilePath=output/audit/audit-log.jsonl
# Optional. Enable or disable audit logging.
Observability__EnableAuditLogging=true

# === Persistence ===
# Optional. Persistence provider: "sqlite" (default, standalone) or "postgres".
OperationalPersistence__Provider=sqlite
# Path for SQLite database file (relative to API project root).
OperationalPersistence__DatabasePath=output/persistence/orkystra-operations.db
# PostgreSQL connection string (required when Provider is "postgres").
OperationalPersistence__ConnectionString=Host=localhost;Port=5432;Database=orkystra;Username=orkystra;Password=orkystra

# === Event Backbone (MQTT) ===
# Optional. MQTT broker URL for the event backbone.
EventBackbone__BrokerUrl=mqtt://localhost:1883
# Optional. Enable or disable the MQTT event backbone.
EventBackbone__Enabled=true
# MQTT topic filter for simulation events.
EventBackbone__SimulationTopicFilter=orkystra/events/simulation/#

# === AI Service ===
# Optional. Base URL of the Python AI recommendation service.
AiService__BaseUrl=http://127.0.0.1:8001
# Optional. HTTP timeout in seconds for AI service calls.
AiService__TimeoutSeconds=8

# === Optimization Service ===
# Optional. Base URL of the Python route optimization service.
OptimizationService__BaseUrl=http://127.0.0.1:8002
# Optional. HTTP timeout in seconds for optimization service calls.
OptimizationService__TimeoutSeconds=8

# === Provider Secrets ===
# Provider secrets use a separate naming convention:
# ORKYSTRA_PROVIDER_{PROVIDER_ID_UPPER}_{FIELD_UPPER}
# Example for the REST transport adapter API key:
# ORKYSTRA_PROVIDER_REST_TRANSPORT_ADAPTER_APIKEY=your-api-key-here
#
# Supported providers and their secret fields:
# - rest-transport-adapter: apiKey
